<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Qase Automation Suite"
       parallel="false">

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Chrome">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="tests.ui.LoginTest"/>
            <class name="tests.ui.LogoutTest"/>
            <class name="tests.ui.ProjectTest"/>
            <class name="tests.ui.SuiteTest"/>
            <class name="tests.ui.TestCaseTest"/>
            <class name="tests.ui.E2ETest"/>
        </classes>
    </test>

    <test name="Firefox">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="tests.ui.LoginTest"/>
            <class name="tests.ui.LogoutTest"/>
            <class name="tests.ui.ProjectTest"/>
            <class name="tests.ui.SuiteTest"/>
            <class name="tests.ui.TestCaseTest"/>
            <class name="tests.ui.E2ETest"/>
        </classes>
    </test>
</suite>
